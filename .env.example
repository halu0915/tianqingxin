# 天擎鑫網站 環境變數範本（複製成 .env.local 並填入實際值）

# 網站正式網址（給 sitemap / SEO 用，例：https://www.tianqingxin.com）
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# 聯絡表單寄信（Resend，https://resend.com/api-keys 取得）
RESEND_API_KEY=re_your_api_key_here

# Google Search Console 網站驗證碼（選填）
NEXT_PUBLIC_GOOGLE_VERIFICATION=your_google_verification_code

# Google Analytics 評估 ID（選填，例：G-XXXXXXXXXX）
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
